# ─── Câmera CSI ──────────────────────────────────────────────────────────────
# Resolução e framerate da câmera conectada ao conector CSI
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_FRAMERATE=30

# ─── Inferência ──────────────────────────────────────────────────────────────
# Caminho para os pesos do modelo (coloque best.pt na pasta weights/)
WEIGHTS=weights/best.pt

# Pasta onde os recortes das pedras detectadas serão salvos (fila de envio)
PASTA_SAIDA=pedras_grandes

# Pasta onde os recortes já enviados ao n8n são movidos (evita reenvio caso
# o processo reinicie). Mantém no máximo ENVIADAS_MAX imagens, apagando as
# mais antigas primeiro.
PASTA_ENVIADAS=pedras_enviadas
ENVIADAS_MAX=300

# Dispositivo de inferência (cpu único suportado no RPi sem acelerador)
DEVICE=cpu

# Parâmetros de detecção
CONF=0.30
IOU=0.45
IMGSZ=640
AREA_MINIMA=0.12
MARGEM_COMPARACAO=22
LIMIAR_HAMMING=30
MIN_FRAMES_CONFIRMACAO=8

# ROI fixo (x, y, largura, altura) — ajuste para o seu campo de visão
# Valores de referência: câmera 1280x720 com britador centralizado
ROI_X=1
ROI_Y=44
ROI_W=945
ROI_H=674

# ─── Frames de debug periódicos ──────────────────────────────────────────────
# A cada FRAMES_DEBUG_INTERVALO segundos, salva 1 frame (com ROI e detecções
# desenhados) em FRAMES_DEBUG_DIR, para conferência visual. A pasta mantém no
# máximo FRAMES_DEBUG_MAX imagens — as mais antigas são apagadas.
FRAMES_DEBUG_DIR=frames_debug
FRAMES_DEBUG_INTERVALO=5
FRAMES_DEBUG_MAX=100

# ─── Webhook (n8n) ───────────────────────────────────────────────────────────
# URL do webhook do n8n (OBRIGATÓRIO). O n8n recebe a imagem em Base64 e cuida
# de todo o tratamento de imagem/mensagem e envio ao WhatsApp.
URL_WEBHOOK=https://seu-n8n-aqui/webhook/identificador
INTERVALO_VERIFICACAO=5
