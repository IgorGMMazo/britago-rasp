# ─── Câmera CSI ──────────────────────────────────────────────────────────────
# Resolução e framerate da câmera conectada ao conector CSI
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_FRAMERATE=30

# ─── Inferência ──────────────────────────────────────────────────────────────
# Caminho para os pesos do modelo (coloque best.pt na pasta weights/)
WEIGHTS=weights/best.pt

# Pasta onde os recortes das pedras detectadas serão salvos
PASTA_SAIDA=pedras_grandes

# Dispositivo de inferência (cpu único suportado no RPi sem acelerador)
DEVICE=cpu

# Parâmetros de detecção
CONF=0.30
IOU=0.45
IMGSZ=640
AREA_MINIMA=0.12
MARGEM_COMPARACAO=22
LIMIAR_HAMMING=30
MIN_FRAMES_CONFIRMACAO=8

# ROI fixo (x, y, largura, altura) — ajuste para o seu campo de visão
# Valores de referência: câmera 1280x720 com britador centralizado
ROI_X=1
ROI_Y=44
ROI_W=945
ROI_H=674

# ─── Webhook ─────────────────────────────────────────────────────────────────
# URL do webhook do WhatsApp (OBRIGATÓRIO)
URL_WEBHOOK=https://seu-webhook-aqui/webhook/identificador
PHONE=5562982878127
MENSAGEM=Pedra grande detectada. A pedra é grande de fato?
INTERVALO_VERIFICACAO=5
